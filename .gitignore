wheels/
*.egg-info/
.installed.cfg
*.egg

# venv
.venv/
venv/
env/

# editors
.vscode/
.idea/
*.swp

# tests
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

