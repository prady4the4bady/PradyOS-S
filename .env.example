# ── LLM Provider ────────────────────────────────────────────────────────
# Controls ALL agent intelligence (Guild, Evolve, Foresight, Critic, Reverie).
# Options: ollama (default, free), nvidia, openai-compat
PRADYOS_LLM_PROVIDER=ollama

# NVIDIA NIM — set provider to "nvidia" and add your API key:
# PRADYOS_LLM_PROVIDER=nvidia
# PRADYOS_LLM_API_KEY=nvapi-<your-key>
# PRADYOS_LLM_MODEL=llama         # alias for meta/llama-3.3-70b-instruct
# PRADYOS_LLM_MAX_TOKENS=1024
# PRADYOS_LLM_TOP_P=0.9

# OpenAI-compatible (Groq, Together, vLLM, etc.):
# PRADYOS_LLM_PROVIDER=openai-compat
# PRADYOS_LLM_BASE_URL=https://api.groq.com/openai/v1
# PRADYOS_LLM_MODEL=llama3-70b-8192
# PRADYOS_LLM_API_KEY=gsk_<your-key>

# ── Agent LLM Backends (opt-in; default = deterministic/heuristic) ───────
PRADYOS_FORESIGHT_LLM=false
PRADYOS_CRITIC_LLM=false
PRADYOS_REVERIE_LLM=false

# ── Core ──────────────────────────────────────────────────────────────
PRADYOS_OPEN_MODE=false
PRADYOS_ASCENT_INTERVAL=300
PRADYOS_REVERIE_INTERVAL=240

# ── Stripe (Enterprise payments) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PRADYOS_STRIPE_PRICE_PRO=price_...
PRADYOS_STRIPE_PRICE_SOVEREIGN=price_...
PRADYOS_STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_SUCCESS_URL=https://your-domain.com/billing/success
STRIPE_CANCEL_URL=https://your-domain.com/billing

# ── Polar.sh (OSS/indie payments) ─────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_...
PRADYOS_POLAR_PRODUCT_PRO=<polar-product-id>
PRADYOS_POLAR_PRODUCT_SOVEREIGN=<polar-product-id>
PRADYOS_POLAR_PRODUCT_ENTERPRISE=<polar-product-id>

# ── Payment provider selector ─────────────────────────────────────────
PRADYOS_PAYMENT_PROVIDER=stripe
