# ── Core ──────────────────────────────────────────────────────────────
PRADYOS_OPEN_MODE=false
PRADYOS_FORESIGHT_LLM=false
PRADYOS_REVERIE_LLM=false

# ── Stripe (Enterprise payments) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PRADYOS_STRIPE_PRICE_PRO=price_...
PRADYOS_STRIPE_PRICE_SOVEREIGN=price_...
PRADYOS_STRIPE_PRICE_ENTERPRISE=price_...
STRIPE_SUCCESS_URL=https://your-domain.com/billing/success
STRIPE_CANCEL_URL=https://your-domain.com/billing

# ── Polar.sh (OSS/indie payments) ─────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_...
PRADYOS_POLAR_PRODUCT_PRO=<polar-product-id>
PRADYOS_POLAR_PRODUCT_SOVEREIGN=<polar-product-id>
PRADYOS_POLAR_PRODUCT_ENTERPRISE=<polar-product-id>

# ── Payment provider selector ─────────────────────────────────────────
# Options: stripe | polar
PRADYOS_PAYMENT_PROVIDER=stripe

# ── Optional LLM keys ────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
