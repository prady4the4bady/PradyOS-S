# AppArmor profile — STUB — IMPERIUM (Plane 3): the orchestration kernel.
#
# IMPERIUM schedules and recovers tasks but does NOT itself run arbitrary
# commands, so it is confined tighter than TITAN: no exec transitions, no setuid,
# no privileged capabilities. Attach via systemd:  AppArmorProfile=pradyos-imperium
#include <tunables/global>

profile pradyos-imperium flags=(attach_disconnected) {
  #include <abstractions/base>
  #include <abstractions/python>
  #include <abstractions/nameservice>

  /opt/pradyos/.venv/bin/python* ix,
  /usr/bin/python3*            ix,
  /opt/pradyos/{,**}            r,
  /opt/pradyos/**.so           mr,
  /usr/lib/python3*/{,**}       r,

  /var/lib/pradyos/{,**}        rw,
  owner /run/pradyos/{,**}      rw,
  /var/log/pradyos/{,**}        w,

  network inet  stream,
  network inet6 stream,
  network unix  stream,
  deny network raw,
  deny network packet,

  deny capability sys_admin,
  deny capability sys_module,
  deny capability sys_rawio,
  deny capability setuid,
  deny capability setgid,
  deny ptrace (read, trace),
  deny mount,
  deny umount,
  deny /etc/shadow      rwklx,
  deny /root/.ssh/**    rwklx,
  deny @{HOME}/.ssh/**  rwklx,
  deny /boot/**         wklx,
}
