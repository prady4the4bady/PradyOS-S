# PRADY OS — Secrets / runtime overrides
# Copy this file to deploy/secrets.env and fill in real values.
# The secrets.env file is gitignored and never baked into the image.
#
# Usage (docker compose):
#   cp deploy/secrets.env.example deploy/secrets.env
#   # edit deploy/secrets.env
#   docker compose up sovereign oracle admission

# ---------------------------------------------------------------------------
# Ollama / AI backend
# ---------------------------------------------------------------------------
# PRADYOS_OLLAMA_URL=http://host.docker.internal:11434
# PRADYOS_ORACLE_MODEL=qwen2.5-coder:1.5b-base

# ---------------------------------------------------------------------------
# Sovereign web API
# ---------------------------------------------------------------------------
# SOVEREIGN_PORT=8000
# SOVEREIGN_CIRCUIT_THRESHOLD=5
# SOVEREIGN_CIRCUIT_RESET_SEC=60

# ---------------------------------------------------------------------------
# Oracle proposal loop
# ---------------------------------------------------------------------------
# PRADYOS_PROPOSAL_INTERVAL=60
# PRADYOS_ORACLE_PORT=11435

# ---------------------------------------------------------------------------
# Logging / observability
# ---------------------------------------------------------------------------
# PRADYOS_LOG_LEVEL=INFO
